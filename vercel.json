{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "web_dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/v1/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/version",
      "destination": "/api/index.py"
    },
    {
      "source": "/images/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/image-thumbnails/:path*",
      "destination": "/api/index.py"
    },
    {
      "source": "/files/:path*",
      "destination": "/api/index.py"
    }
  ]
}

